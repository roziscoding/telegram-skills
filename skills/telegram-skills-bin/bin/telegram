#!/usr/bin/env bash
set -euo pipefail

REPO="roziscoding/telegram-skills"
VERSION="v1.1.0"   # bump together with the release tag

BIN_DIR="$(cd "$(dirname "$0")" && pwd)"
BIN="$BIN_DIR/.telegram-bin-$VERSION"

if [ ! -x "$BIN" ]; then
  os="$(uname -s | tr '[:upper:]' '[:lower:]')"   # linux / darwin
  arch="$(uname -m)"
  case "$arch" in
    x86_64) arch="x64" ;;
    aarch64 | arm64) arch="arm64" ;;
    *) echo "Unsupported architecture: $arch" >&2; exit 1 ;;
  esac
  asset="telegram-$os-$arch"
  url="https://github.com/$REPO/releases/download/$VERSION/$asset"

  echo "Downloading telegram $VERSION ($asset)..." >&2
  if command -v curl &>/dev/null; then
    curl -fsSL -o "$BIN.tmp" "$url"
  elif command -v wget &>/dev/null; then
    wget -qO "$BIN.tmp" "$url"
  else
    echo "Error: neither curl nor wget found" >&2
    exit 1
  fi
  chmod +x "$BIN.tmp"
  mv "$BIN.tmp" "$BIN"
fi

exec "$BIN" "$@"
